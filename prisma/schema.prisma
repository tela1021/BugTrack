generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  name           String?
  hashedPassword String?
  role           String   @default("MEMBER")
  avatarUrl      String?
  preferences    Json?

  createdIssues     Issue[]        @relation("Reporter")
  assignedIssues    Issue[]        @relation("Assignee")
  comments          Comment[]
  teams             TeamMember[]
  history           IssueHistory[]
  notifications     Notification[] @relation("UserNotifications")
  sentNotifications Notification[] @relation("ActorNotifications")
  deletedIssues     Issue[]        @relation("DeletedBy")
  integrationActors TeamIntegration[] @relation("IntegrationActor")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Team {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  issueSequence Int    @default(0)
  slaPolicy     Json?

  members  TeamMember[]
  issues   Issue[]
  cycles   Cycle[]
  labels   Label[]
  statuses WorkflowStatus[]
  projects Project[]
  integrations TeamIntegration[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("teams")
}

model TeamMember {
  id     String @id @default(cuid())
  userId String
  teamId String
  role   String @default("MEMBER")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@map("team_members")
}

model WorkflowStatus {
  id       String @id @default(cuid())
  name     String
  type     String
  position Int
  wipLimit Int?
  teamId   String

  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  issues Issue[]

  @@unique([teamId, name])
  @@unique([teamId, position])
  @@map("workflow_statuses")
}

model Issue {
  id          Int     @id @default(autoincrement())
  readableId  String  @unique
  title       String
  description String?
  priority    String  @default("NONE")
  issueType   String  @default("TASK")

  statusId String
  status   WorkflowStatus @relation(fields: [statusId], references: [id])

  teamId String
  team   Team   @relation(fields: [teamId], references: [id])

  reporterId String
  reporter   User   @relation("Reporter", fields: [reporterId], references: [id])

  assigneeId String?
  assignee   User?   @relation("Assignee", fields: [assigneeId], references: [id])

  cycleId String?
  cycle   Cycle? @relation(fields: [cycleId], references: [id])

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])

  parentId Int?
  parent   Issue?  @relation("ParentChild", fields: [parentId], references: [id])
  children Issue[] @relation("ParentChild")

  deletedAt   DateTime?
  deletedById String?
  deletedBy   User? @relation("DeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)

  comments      Comment[]
  labels        LabelOnIssue[]
  history       IssueHistory[]
  attachments   Attachment[]
  notifications Notification[]
  outgoingLinks IssueLink[] @relation("IssueLinkSource")
  incomingLinks IssueLink[] @relation("IssueLinkTarget")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teamId, statusId])
  @@index([teamId, updatedAt])
  @@index([assigneeId, statusId])
  @@index([projectId, updatedAt])
  @@index([assigneeId])
  @@index([cycleId])
  @@index([issueType])
  @@index([deletedAt])
  @@map("issues")
}

model Project {
  id          String    @id @default(cuid())
  name        String
  description String?
  startDate   DateTime?
  targetDate  DateTime?

  teamId String
  team   Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  issues Issue[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("projects")
  @@index([teamId, updatedAt])
}

model Cycle {
  id       String   @id @default(cuid())
  name     String
  goal     String?
  status   String   @default("DRAFT")
  startsAt DateTime
  endsAt   DateTime
  teamId   String

  team   Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  issues Issue[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teamId, startsAt])
  @@map("cycles")
}

model Comment {
  id        String @id @default(cuid())
  content   String
  issueId   Int
  issue     Issue  @relation(fields: [issueId], references: [id], onDelete: Cascade)
  authorId  String
  author    User   @relation(fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attachments   Attachment[]
  notifications Notification[]

  @@map("comments")
  @@index([issueId, createdAt])
}

model Label {
  id     String @id @default(cuid())
  name   String
  color  String
  teamId String

  team   Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  issues LabelOnIssue[]

  @@unique([teamId, name])
  @@map("labels")
}

model LabelOnIssue {
  issueId Int
  labelId String

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([issueId, labelId])
  @@map("_LabelToIssue")
}

model IssueHistory {
  id      String @id @default(cuid())
  issueId Int
  issue   Issue  @relation(fields: [issueId], references: [id], onDelete: Cascade)
  actorId String
  actor   User   @relation(fields: [actorId], references: [id])
  field   String
  oldValue String?
  newValue String?

  createdAt DateTime @default(now())

  @@map("issue_history")
  @@index([issueId, createdAt])
}

model Attachment {
  id        String @id @default(cuid())
  issueId   Int
  issue     Issue  @relation(fields: [issueId], references: [id], onDelete: Cascade)
  name      String
  url       String
  mimeType  String
  size      Int
  checksum  String  @default("")

  createdAt DateTime @default(now())

  commentId String?
  comment   Comment? @relation(fields: [commentId], references: [id], onDelete: SetNull)

  @@map("attachments")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  actorId   String
  actor     User     @relation("ActorNotifications", fields: [actorId], references: [id])
  issueId   Int
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  commentId String?
  comment   Comment? @relation(fields: [commentId], references: [id], onDelete: SetNull)
  type      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("notifications")
  @@index([userId, read, createdAt])
}

model TeamIntegration {
  id             String   @id @default(cuid())
  teamId         String
  provider       String
  repository     String
  enabled        Boolean  @default(true)
  actorUserId    String
  reviewStatusId String?
  doneStatusId   String?

  team       Team              @relation(fields: [teamId], references: [id], onDelete: Cascade)
  actor      User              @relation("IntegrationActor", fields: [actorUserId], references: [id])
  deliveries WebhookDelivery[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teamId, provider, repository])
  @@index([provider, repository])
  @@map("team_integrations")
}

model WebhookDelivery {
  id            String   @id @default(cuid())
  integrationId String?
  provider      String
  deliveryId    String
  event         String
  payloadHash   String
  status        String   @default("RECEIVED")
  error         String?
  processedAt   DateTime?
  createdAt     DateTime @default(now())

  integration TeamIntegration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)

  @@unique([provider, deliveryId])
  @@index([integrationId, createdAt])
  @@map("webhook_deliveries")
}

model IssueLink {
  id       String @id @default(cuid())
  sourceId Int
  targetId Int
  relation String

  source Issue @relation("IssueLinkSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target Issue @relation("IssueLinkTarget", fields: [targetId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([sourceId, targetId, relation])
  @@index([targetId])
  @@map("issue_links")
}
